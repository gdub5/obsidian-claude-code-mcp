		"test:coverage": "vitest run --coverage",
		"test:integration": "node tests/integration/stress.mjs",
		"test-vault:setup": "./scripts/setup-test-vault.sh",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [],
