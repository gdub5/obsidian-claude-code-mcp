	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.15.30",
		"@types/ws": "^8.18.1",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"@vitest/coverage-v8": "^4.1.5",
		"builtin-modules": "3.3.0",
		"esbuild": "^0.25.5",
		"eventsource": "^4.0.0",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@xterm/addon-fit": "0.10.0",
